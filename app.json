{
  "expo": {
    "name": "Levainier",
    "slug": "levainier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "levainier",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.levainier.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour scanner les QR codes de protocoles."
      }
    },
    "android": {
      "package": "com.levainier.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A1A1A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "ACCESS_NOTIFICATION_POLICY",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "benoitdw.github.io",
              "pathPrefix": "/laCuisineDeBenoit/pain/chrono/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "levainier"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "sounds": [
            "./src/assets/sounds/bell.wav",
            "./src/assets/sounds/alarm.wav"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Pour scanner les QR codes de protocoles Levainier."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0ff29999-7d88-4cf2-bcfa-4d8c1e6a11ad"
      }
    },
    "owner": "ermite"
  }
}
